ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://trainer:trainer@localhost:5433/trainer
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI — OpenRouter (free models: https://openrouter.ai/models?q=free)
# Sign up at https://openrouter.ai to get a free API key
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Embeddings use sentence-transformers locally (no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Auth
SECRET_KEY=generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
